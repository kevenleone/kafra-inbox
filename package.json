{
    "name": "mail4all",
    "version": "1.0.0",
    "description": "Email sandbox for testing",
    "module": "server/index.ts",
    "type": "module",
    "private": true,
    "scripts": {
        "dev": "bun --hot src/server/index.ts",
        "start": "bun src/server/index.ts",
        "build": "bun build src/client/index.html --outdir dist",
        "lint": "oxlint --config .oxlintrc.json src",
        "lint:fix": "oxlint --fix --config .oxlintrc.json src"
    },
    "dependencies": {
        "@tanstack/react-query": "^5.96.2",
        "clsx": "^2.1.1",
        "lucide-react": "^1.7.0",
        "mailparser": "^3.7.1",
        "react": "^18.3.1",
        "react-dom": "^18.3.1",
        "react-router-dom": "^7.14.0",
        "smtp-server": "^3.13.4"
    },
    "devDependencies": {
        "@types/bun": "latest",
        "@types/mailparser": "^3.4.4",
        "@types/react": "^18.3.3",
        "@types/react-dom": "^18.3.0",
        "@types/smtp-server": "^3.5.10",
        "oxlint": "^1.58.0"
    },
    "peerDependencies": {
        "typescript": "^5"
    }
}
